# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# CORS — comma-separated allowed origins (set to your Vercel URL in production)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT
JWT_SECRET_KEY=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email / SMTP (for OTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# OTP
OTP_EXPIRY_MINUTES=10
MAX_OTP_ATTEMPTS=5

# Google APIs
# GOOGLE_PLACES_API_KEY powers hotel search (Nearby Search) and activity search (tourist_attraction).
# Make sure "Places API" and "Geocoding API" are both enabled in your Google Cloud Console.
GOOGLE_PLACES_API_KEY=your-google-places-api-key
GOOGLE_API_KEY=your-google-generative-ai-key

# Mapbox (route optimization)
MAPBOX_TOKEN=your-mapbox-token
